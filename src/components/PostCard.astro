---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const formattedDate = post.data.pubDate.toLocaleDateString("ko-KR", {
  year: "numeric",
  month: "short",
  day: "numeric"
});
---

<a class="post-card article-link" href={`/posts/${post.id}/`} aria-label={`${post.data.title} 글 읽기`}>
  <div class="post-card-main">
    <p class="article-meta">
      {post.data.proof && <span class="proof-label">{post.data.proof}</span>}
      {post.data.category} · {post.data.author} · <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
    </p>
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
  </div>
  <ul class="tag-list" aria-label="태그">
    {post.data.tags.slice(0, 2).map((tag) => <li><span class="tag">{tag}</span></li>)}
  </ul>
</a>
