---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getRepresentativePosts } from "@lib/posts";

const posts = await getRepresentativePosts();
---

<BaseLayout title="Posts - 박원창" description="백엔드 설계와 운영 안정성에 대한 글 목록">
  <main>
    <section class="site-shell section">
      <p class="eyebrow">Posts</p>
      <h1>기술 기록</h1>
      <p class="lead">
        실제 회사 코드를 공개하지 않고, 문제와 설계 판단을 일반화해 정리한 백엔드 엔지니어링 노트입니다.
      </p>
    </section>
    <section class="site-shell post-list">
      {
        posts.map((post) => (
          <a class="post-row article-link" href={`/posts/${post.id}/`}>
            <p class="article-meta">
              {post.data.proof && <span class="proof-label">{post.data.proof}</span>}
              {post.data.category} · {post.data.author}
              <br />
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("ko-KR", {
                  year: "numeric",
                  month: "short",
                  day: "numeric"
                })}
              </time>
            </p>
            <div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <ul class="tag-list" aria-label="Tags">
                {post.data.tags.map((tag) => <li><span class="tag">{tag}</span></li>)}
              </ul>
            </div>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
