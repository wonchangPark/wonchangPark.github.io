---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getRepresentativePosts } from "@lib/posts";

const posts = await getRepresentativePosts();
const techStackOrder = [
  "Java / Spring",
  "PostgreSQL / JPA",
  "AWS / Infra",
  "Security / Auth",
  "Messaging / Async"
];
const techStackCounts = posts.reduce((counts, post) => {
  post.data.techStacks.forEach((techStack) => {
    const count = counts.get(techStack) ?? 0;
    counts.set(techStack, count + 1);
  });

  return counts;
}, new Map<string, number>());
const orderedTechStacks = techStackOrder
  .map((name) => ({ name, count: techStackCounts.get(name) ?? 0 }))
  .filter((techStack) => techStack.count > 0);
const extraTechStacks = Array.from(techStackCounts, ([name, count]) => ({ name, count }))
  .filter((techStack) => !techStackOrder.includes(techStack.name))
  .sort((a, b) => a.name.localeCompare(b.name));
const techStacks = [...orderedTechStacks, ...extraTechStacks];
---

<BaseLayout title="Posts - 박원창" description="백엔드 설계와 운영 안정성에 대한 글 목록">
  <main>
    <section class="site-shell section">
      <p class="eyebrow">Posts</p>
      <h1>기술 기록</h1>
      <p class="lead">
        실제 회사 코드를 공개하지 않고, 문제와 설계 판단을 일반화해 정리한 백엔드 엔지니어링 노트입니다.
      </p>
    </section>
    <section class="site-shell post-browser" data-post-browser>
      <div class="post-stream">
        <div class="post-list-head">
          <div>
            <p class="section-label">전체 글</p>
            <h2>문제별 기술 기록</h2>
          </div>
          <p class="post-count" data-post-count>{posts.length}개 글</p>
        </div>
        <div class="post-list" data-post-list>
          {
            posts.map((post) => (
              <a
                class="post-row article-link"
                href={`/posts/${post.id}/`}
                aria-label={`${post.data.title} 글 읽기`}
                data-post-tech-stacks={post.data.techStacks.join("|")}
              >
                <p class="article-meta post-row-meta">
                  {post.data.proof && <span class="proof-label">{post.data.proof}</span>}
                  <span>{post.data.category} · {post.data.author}</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString("ko-KR", {
                      year: "numeric",
                      month: "short",
                      day: "numeric"
                    })}
                  </time>
                </p>
                <div>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  <ul class="tag-list" aria-label="태그">
                    {post.data.tags.map((tag) => <li><span class="tag">{tag}</span></li>)}
                  </ul>
                </div>
              </a>
            ))
          }
        </div>
      </div>
      <aside class="category-filter" aria-labelledby="category-filter-title">
        <div class="category-filter-head">
          <div>
            <p class="section-label">Tech Stack</p>
            <h2 id="category-filter-title">기술 스택</h2>
          </div>
          <button class="filter-reset" type="button" data-filter-reset disabled>초기화</button>
        </div>
        <ul class="category-filter-list" aria-label="기술 스택 필터">
          {
            techStacks.map((techStack) => (
              <li>
                <button
                  class="category-filter-option"
                  type="button"
                  data-filter-value={techStack.name}
                  aria-pressed="false"
                >
                  <span class="filter-box" aria-hidden="true"></span>
                  <span>{techStack.name}</span>
                  <span class="filter-count">{techStack.count}</span>
                </button>
              </li>
            ))
          }
        </ul>
      </aside>
    </section>
  </main>
  <script>
    const postBrowser = document.querySelector("[data-post-browser]");

    if (postBrowser) {
      const rows = Array.from(postBrowser.querySelectorAll("[data-post-tech-stacks]"));
      const controls = Array.from(postBrowser.querySelectorAll("[data-filter-value]"));
      const countLabel = postBrowser.querySelector("[data-post-count]");
      const resetButton = postBrowser.querySelector<HTMLButtonElement>("[data-filter-reset]");
      const filterValues = new Set<string>(
        controls
          .map((control) => control.getAttribute("data-filter-value"))
          .filter((value): value is string => value !== null)
      );
      let activeTechStacks = new Set<string>();

      const getRowTechStacks = (row: Element) =>
        row.getAttribute("data-post-tech-stacks")?.split("|").filter(Boolean) ?? [];

      const setSelectedTechStacks = (techStacks: string[], writeHistory = true) => {
        const selectedValues = techStacks.filter((techStack) => filterValues.has(techStack));
        const selected = new Set(selectedValues);
        const hasChanged =
          selected.size !== activeTechStacks.size ||
          selectedValues.some((techStack) => !activeTechStacks.has(techStack));
        let visibleCount = 0;

        rows.forEach((row) => {
          const rowTechStacks = getRowTechStacks(row);
          const shouldShow =
            selected.size === 0 || rowTechStacks.some((techStack) => selected.has(techStack));
          row.toggleAttribute("hidden", !shouldShow);
          if (shouldShow) visibleCount += 1;
        });

        controls.forEach((control) => {
          const value = control.getAttribute("data-filter-value");
          const isActive = value !== null && selected.has(value);
          control.classList.toggle("is-active", isActive);
          control.setAttribute("aria-pressed", String(isActive));
        });

        if (countLabel) {
          countLabel.textContent =
            selected.size === 0 ? `${rows.length}개 글` : `${visibleCount}개 글 · ${selected.size}개 기술 선택`;
        }

        if (resetButton) {
          resetButton.disabled = selected.size === 0;
        }

        if (writeHistory && hasChanged) {
          const url = new URL(window.location.href);
          url.searchParams.delete("category");
          url.searchParams.delete("tech");
          selectedValues.forEach((techStack) => url.searchParams.append("tech", techStack));
          window.history.pushState({ tech: selectedValues }, "", url);
        }

        activeTechStacks = selected;
      };

      const readSelectedTechStacksFromUrl = () => {
        const params = new URLSearchParams(window.location.search);
        return params.getAll("tech");
      };

      setSelectedTechStacks(readSelectedTechStacksFromUrl(), false);

      controls.forEach((control) => {
        control.addEventListener("click", () => {
          const value = control.getAttribute("data-filter-value");
          if (!value) return;

          const nextSelection = new Set(activeTechStacks);
          if (nextSelection.has(value)) {
            nextSelection.delete(value);
          } else {
            nextSelection.add(value);
          }

          setSelectedTechStacks(Array.from(nextSelection));
        });
      });

      resetButton?.addEventListener("click", () => {
        setSelectedTechStacks([]);
      });

      window.addEventListener("popstate", () => {
        setSelectedTechStacks(readSelectedTechStacksFromUrl(), false);
      });
    }
  </script>
</BaseLayout>
